# Automation Station — Example Configuration
#
# Copy this file to `.env` and fill in your real values:
#   cp env.example .env
#
# Or run `automation-station-launch` with no .env present and the launcher
# will walk you through an interactive setup.

# ─── Network ──────────────────────────────────────────────────────────
# The subnet to scan, in CIDR notation
SUBNET=192.168.1.0/24

# DHCP pool range — only leases inside this range will be reported
DHCP_POOL_START=192.168.1.100
DHCP_POOL_END=192.168.1.250

# ─── NetBox ───────────────────────────────────────────────────────────
# NetBox base URL (no trailing slash)
NETBOX_URL=http://netbox.example.com

# NetBox API token — must be a v1 token (not v2/Bearer)
# Generate one at: <NETBOX_URL>/user/api-tokens/
NETBOX_TOKEN=your-netbox-token-here

# ─── Confidence Scoring ───────────────────────────────────────────────
# Devices with overall scores below this are still pushed, but flagged
CONFIDENCE_THRESHOLD=75

# Internal scoring threshold (0.0–1.0)
SCORE_THRESHOLD=0.5

# ─── SNMP ─────────────────────────────────────────────────────────────
SNMP_COMMUNITY=public
SNMP_VERSION=2c
SNMP_TARGET_SUBNET=192.168.1.0/24

# Standard SNMP OIDs — these defaults work for most devices
SNMP_OID_HOSTNAME=1.3.6.1.2.1.1.5.0
SNMP_OID_DESCRIPTION=1.3.6.1.2.1.1.1.0
SNMP_OID_UPTIME=1.3.6.1.2.1.1.3.0
SNMP_OID_INTERFACES=1.3.6.1.2.1.2.2.1.2

# ─── DNS ──────────────────────────────────────────────────────────────
DNS_SERVER=192.168.1.1
DNS_DOMAIN=example.com

# ─── Kea DHCP REST API ────────────────────────────────────────────────
KEA_API_URL=http://kea.example.com:8000
KEA_API_USERNAME=kea-user
KEA_API_PASSWORD=kea-password
KEA_COMMAND=lease4-get-all
KEA_SERVICE=dhcp4

# ─── Email Reporting ──────────────────────────────────────────────────
# Devices scoring below MAIL_REPORT_THRESHOLD trigger an email alert
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-username
SMTP_PASS=smtp-password
MAIL_FROM=automation-station@example.com
MAIL_TO=admin@example.com,ops@example.com
MAIL_REPORT_THRESHOLD=40

# ─── Database ─────────────────────────────────────────────────────────
# Optional — defaults to local SQLite file if omitted
DATABASE_URL=sqlite:///scan_results.db